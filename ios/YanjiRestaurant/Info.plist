	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>yanjireact</string>
				<string>com.yanjirestaurant.app</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>exp+yanji-app</string>
			</array>
		</dict>
	</array>
