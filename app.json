{
  "expo": {
    "name": "Yanji Restaurant",
    "slug": "yanji-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yanjireact",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yanjirestaurant.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocalNetworkUsageDescription": "This app needs access to your local network",
        "NSBonjourServiceTypes": [
          "_http._tcp",
          "_https._tcp"
        ],
        "NSBluetoothAlwaysUsageDescription": "This app uses Bluetooth to connect to receipt printers on your local network",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yanjirestaurant.app"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "5dd32043-7957-429c-b5c5-b5156aa612d8"
      },
      "apiBase": "http://localhost:3001",
      "webviewUrl": "http://localhost:5173/dashboard",
      "env": "development",
      "demoUser": true,
      "demoUserId": "nohjiyoung@hotmail.com",
      "demoPassword": "Yoomin10!",
      "squareTerminalDeviceId": "145CS145A8001120"
    }
  }
}
